{
  "name": "web-cv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npx --yes serve@latest out",
    "generate:og": "tsx scripts/generate-og.tsx",
    "cf:dev": "pnpm build && pnpm exec wrangler pages dev ./out",
    "precf:deploy": "pnpm exec wrangler whoami || pnpm exec wrangler login",
    "cf:deploy": "pnpm build && pnpm exec wrangler pages deploy ./out",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-slot": "^1.0.2",
    "@vercel/analytics": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^0.2.0",
    "lucide-react": "^0.300.0",
    "next": "14.2.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vercel/og": "^0.8.6",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "satori": "^0.19.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.15.7",
    "typescript": "^5",
    "wrangler": "^4.66.0"
  }
}
